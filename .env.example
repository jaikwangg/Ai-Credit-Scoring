OLLAMA_BASE_URL=http://localhost:11434
# Recommended Thai LLM models (pull in Ollama first):
# seallm3:8b - Good Thai support, 8GB RAM
# typhoon-v1.5-8b-instruct - Best Thai model, 8GB RAM
# typhoon-v1.5x-70b-instruct - Best quality, 40GB+ RAM
OLLAMA_MODEL=seallm3:8b
# BGE-M3: Best multilingual embedding for Thai (1024 dim, 8192 context)
EMBED_MODEL=BAAI/bge-m3
DATA_DIR=./data/documents
INDEX_DIR=./storage/index
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION=credit_policies
SIMILARITY_CUTOFF=0.45
RESET_CHROMA_COLLECTION_ON_INGEST=true

# Planner response-speed controls (production defaults)
# false = deterministic renderer (faster), true = add extra LLM synthesis pass
PLANNER_ENABLE_LLM_SYNTHESIS=false
PLANNER_MAX_ACTION_DRIVERS=3
PLANNER_MAX_RAG_QUERIES_PER_DRIVER=1
PLANNER_APPROVED_MAX_RAG_QUERIES=2

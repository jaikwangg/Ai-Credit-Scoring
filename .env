USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
# Available models in Ollama (pull first with: ollama pull <model>)
# llama3:8b - Strong general purpose model
# qwen2.5:7b - Good multilingual support including Thai
# gemma2:9b - Google's model with good multilingual support
OLLAMA_MODEL=llama3:8b
# BGE-M3: Best multilingual embedding model for Thai (1024 dim)
EMBED_MODEL=BAAI/bge-m3
DATA_DIR=./data/documents
INDEX_DIR=./storage/index
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION=cimb_loans_bge_m3
